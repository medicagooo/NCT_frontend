# 独立表单 Workers 本地开发示例。
# Cloudflare 官方文档说明：`.dev.vars` 需要和 wrangler 配置文件放在同一目录。
# 复制为 `.dev.vars` 后再运行 `npm run dev` 或 `npx wrangler dev -c wrangler.jsonc`。
#
# 这个文件只为 standalone/form-worker 服务。
# 它复用了主仓库里的共享配置读取逻辑，所以变量名尽量与根目录 `.env.example` 保持一致。

# 优先填写

# Workers 本地调试时固定设为 workers。
RUNTIME_TARGET="workers"

# 独立问卷包固定使用 legacy 模板，不需要改成 react。
FRONTEND_VARIANT="legacy"

# 站点正式网址，用于 canonical、调试页和派生配置。
SITE_URL="https://form.example.workers.dev"

# 是否开启调试模式。
# 设为 true 时可访问 /debug、/debug/submit-success、/debug/submit-error。
DEBUG_MOD="true"

# 是否只预览提交而不真正发送。
# 本地开发建议先保持 true。
FORM_DRY_RUN="true"

# 提交目标。
# 可选 google、d1、both；默认 both。
FORM_SUBMIT_TARGET="both"

# 表单保护签名密钥。
# 如果使用 FORM_ID_ENCRYPTED / GOOGLE_SCRIPT_URL_ENCRYPTED，必须显式填写。
FORM_PROTECTION_SECRET=""

# Google Form 的明文 ID。
# 与 FORM_ID_ENCRYPTED 二选一；两者都留空时会回退到内置默认主表单。
FORM_ID=""

# 加密后的 Google Form ID。
# 与 FORM_ID 二选一；两者都留空时会回退到内置默认主表单。
FORM_ID_ENCRYPTED=""

# 自动补全与地图数据来源。
# GOOGLE_SCRIPT_URL 与 GOOGLE_SCRIPT_URL_ENCRYPTED 二选一。
GOOGLE_SCRIPT_URL=""
GOOGLE_SCRIPT_URL_ENCRYPTED=""
PUBLIC_MAP_DATA_URL="https://nct.hosinoeiji.workers.dev/api/map-data"

# 按需填写

# 是否开启维护模式。
MAINTENANCE_MODE="false"

# 维护公告文案。
MAINTENANCE_NOTICE=""

# 维护模式响应里的 Retry-After 秒数。
MAINTENANCE_RETRY_AFTER_SECONDS="1800"

# 页面读取限流：5 分钟内最多访问页面次数。
PAGE_READ_RATE_LIMIT_MAX="180"

# 公共地图接口限流：5 分钟内最多读取 /api/map-data 次数。
MAP_READ_RATE_LIMIT_MAX="60"

# 表单提交限流：15 分钟内最多提交次数。
SUBMIT_RATE_LIMIT_MAX="5"

# 共享限流 Redis 地址。
# 多实例或需要共享限流时再填。
RATE_LIMIT_REDIS_URL=""

# RATE_LIMIT_REDIS_URL 的兼容别名。
REDIS_URL=""

# D1 绑定变量名。
# 默认通常不填，只有你在 Workers 里把 D1 绑定名改掉时才需要。
D1_BINDING_NAME=""

# 公开站点标题。
TITLE="N·C·T"

# 表单最短填写时间，单位为毫秒。
FORM_PROTECTION_MIN_FILL_MS="3000"

# 表单保护令牌最长有效期，单位为毫秒。
FORM_PROTECTION_MAX_AGE_MS="86400000"

# 地图上游请求超时时间，单位为毫秒。
MAP_DATA_UPSTREAM_TIMEOUT_MS="25000"

# 翻译服务 API Key。
# standalone 包通常不会主动用到翻译接口，但如果你复用维护文案等场景，可按需配置。
GOOGLE_CLOUD_TRANSLATION_API_KEY=""

# 翻译请求超时时间，单位为毫秒。
TRANSLATION_PROVIDER_TIMEOUT_MS="10000"

# 通常可保持默认或留空

# Workers 本地调试通常保持 true 即可。
TRUST_PROXY="true"

# 仅限 Node 运行时的地图网络覆盖能力。
# Workers 会忽略该开关，通常保持 false。
MAP_DATA_NODE_TRANSPORT_OVERRIDES="false"

# Node 代理配置。
# Workers 本地调试通常不会用到，留空即可。
HTTPS_PROXY=""
HTTP_PROXY=""
ALL_PROXY=""
https_proxy=""
http_proxy=""
all_proxy=""

# Cloudflare 平台通常会自动注入，Wrangler 本地调试一般无需手动设置。
CF_PAGES=""

# 静态资源版本号。
# 留空时应用会自动生成。
ASSET_VERSION=""

# 说明：
# 1. standalone/form-worker 不使用 correction 提交流程，所以这里不列 CORRECTION_* 变量。
# 2. Worker 上线后，正式环境变量请配置在 Cloudflare Dashboard 的 Variables & Secrets 中。
