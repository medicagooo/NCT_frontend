    "node": "20.x"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "china-area-data": "^5.0.1",
    "cors": "^2.8.6",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "fs": "^0.0.1-security",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "marked": "^4.3.0",
    "node-fetch": "^3.3.2",
    "path": "^0.12.7",
    "proxy-agent": "^8.0.1",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
