{
  "name": "nct_frontend",
  "version": "1.0.0",
  "description": "",
  "main": "index.html",
  "scripts": {
    "build": "npm run frontend:build",
    "dev": "vite --host",
    "frontend:build": "npm run frontend:prepare-content && vite build",
    "frontend:preview": "vite preview --host",
    "frontend:prepare-content": "node scripts/generate-frontend-content.js",
    "frontend:dev": "vite --host",
    "deploy:workers": "npm run frontend:build && npx wrangler deploy",
    "deploy:workers:preview": "npm run frontend:build && npx wrangler versions upload",
    "start": "vite preview --host",
    "test": "npm run test:unit && npm run frontend:build",
    "test:unit": "node --test tests/*.test.js",
    "playwright:install": "npx playwright install chromium",
    "dev:workers": "npm run frontend:build && npx wrangler dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
