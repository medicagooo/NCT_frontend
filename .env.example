# 本文件按“推荐填写程度”排序：
# 1. 优先填写：大多数部署最先需要确认的核心变量。
# 2. 按需填写：启用特定能力或采用特定部署方式时再填写。
# 3. 通常可保持默认或留空：高级、调试或兼容项。

# 优先填写

# 站点正式网址，用于 sitemap、robots 和 canonical 链接。
SITE_URL="https://www.victimsunion.org/"

# 是否开启调试模式。生产环境建议设为 false。
DEBUG_MOD="true"

# 是否只预览提交而不真正发送到 Google Form。
# 本地开发建议保持 true，确认无误后再改为 false。
FORM_DRY_RUN="true"

# 表单保护签名密钥。
# 正式环境强烈建议显式设置高强度随机值。
# 可用以下命令生成：
# npm run secure-config -- generate-secret
# npm run secure-config -- bootstrap-env --env-file ".env"
# npm run secure-config -- bootstrap --form-id "your-Google-Form-ID" --google-script-url "your-Google-Script-URL"
FORM_PROTECTION_SECRET="replace-this-with-a-long-random-secret"

# Google Form 的明文 ID。
# 与 FORM_ID_ENCRYPTED 二选一；如果使用密文版本，这里留空。
FORM_ID=""

# 加密后的 Google Form ID。
# 与 FORM_ID 二选一；使用时必须显式配置 FORM_PROTECTION_SECRET。
# 可用以下命令生成：
# npm run secure-config -- bootstrap-env --env-file ".env"
# npm run secure-config -- bootstrap --form-id "your-Google-Form-ID" --google-script-url "your-Google-Script-URL"
# npm run secure-config -- encrypt --purpose form-id --secret "your-FORM_PROTECTION_SECRET" --value "your-Google-Form-ID"
FORM_ID_ENCRYPTED=""

# 私有 Google Apps Script 数据源地址。
# 与 GOOGLE_SCRIPT_URL_ENCRYPTED 二选一；如果你只使用公开地图 API，可以留空。
GOOGLE_SCRIPT_URL=""

# 加密后的私有 Google Apps Script 数据源地址。
# 与 GOOGLE_SCRIPT_URL 二选一；使用时必须显式配置 FORM_PROTECTION_SECRET。
# 可用以下命令生成：
# npm run secure-config -- bootstrap-env --env-file ".env"
# npm run secure-config -- bootstrap --form-id "your-Google-Form-ID" --google-script-url "your-Google-Script-URL"
# npm run secure-config -- encrypt --purpose google-script-url --secret "your-FORM_PROTECTION_SECRET" --value "your-Google-Script-URL"
GOOGLE_SCRIPT_URL_ENCRYPTED=""

# 公开地图数据回退源。
# 当私有 Google Apps Script 数据源较慢或暂时不可用时，会回退到这里。
# 如果你自托管且没有私有数据源，可以直接把它指向你自己的公开地图接口。
PUBLIC_MAP_DATA_URL="https://nct.hosinoeiji.workers.dev/api/map-data"

# 按需填写

# Google Cloud Translation API Key。
# 只有启用翻译功能时才需要配置。
GOOGLE_CLOUD_TRANSLATION_API_KEY=""

# GOOGLE_CLOUD_TRANSLATION_API_KEY 的兼容旧别名。
# 新配置优先使用 GOOGLE_CLOUD_TRANSLATION_API_KEY。
GOOGLE_TRANSLATE_API_KEY=""

# 翻译请求超时时间，单位为毫秒。
TRANSLATION_PROVIDER_TIMEOUT_MS="10000"

# 是否开启全站维护模式。
MAINTENANCE_MODE="false"

# 维护公告文字。
# 建议直接填写原文；英文和繁中页面在配置翻译服务后会尝试自动翻译，失败时回退原文。
MAINTENANCE_NOTICE=""

# 维护模式响应里的 Retry-After 秒数。
MAINTENANCE_RETRY_AFTER_SECONDS="1800"

# 页面读取限流：单个客户端 IP 在 5 分钟内最多访问页面的次数。
PAGE_READ_RATE_LIMIT_MAX="180"

# 公共地图接口限流：单个客户端 IP 在 5 分钟内最多读取 /api/map-data 的次数。
MAP_READ_RATE_LIMIT_MAX="60"

# 表单提交限流：单个客户端 IP 在 15 分钟内最多提交的次数。
SUBMIT_RATE_LIMIT_MAX="5"

# 共享限流 Redis 地址。
# 多实例部署时建议配置；单实例部署可留空。
RATE_LIMIT_REDIS_URL="rediss://default:password@your-redis-host:6379"

# RATE_LIMIT_REDIS_URL 的兼容别名。
# 如果你已经在旧环境里使用 REDIS_URL，可以继续保留；新的配置优先使用 RATE_LIMIT_REDIS_URL。
REDIS_URL=""

# 是否信任反向代理头。
# 部署在 Nginx、Cloudflare 等反向代理后面时通常保持 true。
TRUST_PROXY="true"

# Node 服务监听端口。
PORT="3000"

# 是否开启仅限 Node 运行时的地图上游网络覆盖能力。
# 设为 true 后，才会启用代理环境变量与 IPv4 直连回退；Cloudflare Workers 会忽略该开关。
MAP_DATA_NODE_TRANSPORT_OVERRIDES="false"

# 地图上游请求超时时间，单位为毫秒。
# 如果你的地图数据源长期较慢，可以适当调大。
MAP_DATA_UPSTREAM_TIMEOUT_MS="25000"

# 代理配置。
# 仅当 MAP_DATA_NODE_TRANSPORT_OVERRIDES=true 时，Node 运行时才会读取这些变量。
# 很多系统会使用大写或小写形式，应用两种写法都会识别；通常只需要配置你实际使用的一组。
HTTPS_PROXY=""
HTTP_PROXY=""
ALL_PROXY=""
https_proxy=""
http_proxy=""
all_proxy=""

# 通常可保持默认或留空

# 站点标题，会显示在页面标题等位置。
TITLE="N·C·T"

# 表单最短填写时间，单位为毫秒。
# 过快提交会被视为异常请求。
FORM_PROTECTION_MIN_FILL_MS="3000"

# 表单保护令牌的最长有效期，单位为毫秒。
FORM_PROTECTION_MAX_AGE_MS="86400000"

# 运行时目标。
# 本地 Node 运行通常留空；本地调试 Cloudflare Workers 时可设为 workers。
RUNTIME_TARGET=""

# Cloudflare Pages/Workers 运行时识别标记。
# Cloudflare 平台通常会自动注入 CF_PAGES=1，本地一般无需手动设置。
CF_PAGES=""

# 静态资源版本号。
# 留空时应用会在启动时自动生成；只有在你想手动固定资源版本时才需要设置。
ASSET_VERSION=""
