# Copy to `.env` before running local frontend development:
# cp .env.example .env
#
# Only `VITE_*` variables are exposed to the browser runtime.
#
# Sort order by how likely you must change the value:
# 1. Change for linked production deployment
# 2. Platform-managed flags, usually leave blank

# No-Torsion root is now a frontend-only Vite + React site.
# Legacy Express / EJS configuration has been moved to `../NCT_old/.env.example`.

# 1) Change for linked production deployment.
# Public JSON dataset used by the map and detail pages.
# Recommended values:
# - Local linked test: `http://127.0.0.1:8787/`
# - Production linked deploy: `https://api.example.com/`
# - Static-only fallback: keep `/content/map-data.json`
VITE_NCT_API_SQL_PUBLIC_DATA_URL="/content/map-data.json"

# Standalone Hono form page hosted by `nct-api-sql-sub`.
# When configured:
# - No-Torsion shows the "填写表单" entry and keeps users on the frontend `/form`
#   route while embedding this backend form page
# - No-Torsion runtime translation calls the same origin's `/api/no-torsion/translate-text`
# - Frontend deployment mode is treated as `hono`
# When left empty:
# - No-Torsion hides the "填写表单" entry
# - No-Torsion does not call the runtime translation API
# - Frontend deployment mode is treated as `api-only`
# Example: `https://sub.example.com/form`
VITE_NCT_SUB_FORM_URL=""

# 2) Platform-managed flags, usually leave blank.
# These are typically injected by the hosting/runtime layer instead of being set
# by hand in local frontend development.
RUNTIME_TARGET=""
CF_PAGES=""
