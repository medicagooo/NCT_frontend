<%- include('partials/head', {
    includeLeafletCss: true,
    extraHeadPartial: 'partials/map_head'
}) %>
<body class="map-page">
    <a href="/" class="page-back-link">← <%= t('navigation.home') %></a>
    <script src="/js/map_data_store.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_time_utils.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_record_stats.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_record_detail.js?v=<%= assetVersion %>"></script>
    <h1><%= t('map.title') %></h1>
    <h2 class="map-section-title"><%= t('map.sections.stats') %></h2>
    <%- include('partials/map_allnum') %>
    <h2 class="map-section-title"><%= t('map.sections.tags') %></h2>
    <%- include('partials/map_tag') %>
    <h2 class="map-section-title"><%= t('map.sections.map') %></h2>
    <small><%= t('map.note') %></small>
    <div id="map" class="div"></div>
    <%- include('partials/map_apimd') %>
    <h2 class="map-section-title"><%= t('map.sections.allData') %></h2>
    <%- include('partials/map_list') %>
    <button id="backToTop" type="button">↑</button>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin="anonymous"
    ></script>
    <script>
        window.PROVINCE_METADATA = <%- JSON.stringify(provinceMetadata || {}) %>;
    </script>
    <script src="/js/map_province_utils.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_api.js?v=<%= assetVersion %>"></script>
    <%- include('partials/foot', {
        includeBackToTopScript: true,
        includeQueryUpdScript: true
    }) %>
</body>
</html>
