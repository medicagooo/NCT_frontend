<%- include('partials/head') %>
<body class="form-page">
<a href="/" class="page-back-link">← <%= t('navigation.home') %></a>

<div class="container">
    <h1><%= t('form.title') %></h1>
    <p class="form-subtitle"><%= t('form.subtitle') %></p>

    <form action="/submit" method="POST" id="mainForm">
        <div class="form-honeypot" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" spellcheck="false">
        </div>
        <input type="hidden" name="form_token" value="<%= formProtectionToken %>">

        <h3><%= t('form.sections.basic') %></h3>
        
        <div class="form-group">
            <label class="required"><%= t('form.fields.identity') %></label>
            <select name="identity" id="identitySelect" required>
                <% identityOptions.forEach((option) => { %>
                    <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label class="required" id="birthDateLabel" for="birthYearSelect"><%= t('form.fields.birthDate') %></label>
            <div class="birth-date-group" role="group" aria-labelledby="birthDateLabel">
                <select name="birth_year" id="birthYearSelect" required>
                    <option value="" selected><%= t('form.placeholders.birthYear') %></option>
                    <% for (let year = formRules.birthYear.max; year >= formRules.birthYear.min; year -= 1) { %>
                        <option value="<%= year %>"><%= year %></option>
                    <% } %>
                </select>
                <select name="birth_month" id="birthMonthSelect" required>
                    <option value="" selected><%= t('form.placeholders.birthMonth') %></option>
                    <% for (let month = formRules.birthMonth.min; month <= formRules.birthMonth.max; month += 1) { %>
                        <option value="<%= month %>"><%= month %></option>
                    <% } %>
                </select>
                <select name="birth_day" id="birthDaySelect" required>
                    <option value="" selected><%= t('form.placeholders.birthDay') %></option>
                    <% for (let day = formRules.birthDay.min; day <= formRules.birthDay.max; day += 1) { %>
                        <option value="<%= day %>"><%= day %></option>
                    <% } %>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="required"><%= t('form.fields.sex') %></label>
            <select name="sex" id="sexSelect" required>
                <option value="" disabled selected><%= t('form.sexOptions.placeholder') %></option>
                <% sexOptions.forEach((option) => { %>
                    <option value="<%= option.value %>"><%= option.label %></option>
                <% }) %>
            </select>
            <input type="text" id="otherSexInput" name="sex_other" class="other-input" placeholder="<%= t('form.placeholders.otherSex') %>" maxlength="<%= formRules.sexOther.maxLength %>" hidden>
        </div>

        <div class="form-group">
            <label class="required"><%= t('form.fields.province') %></label>
            <select name="provinceCode" id="provinceSelect" required>
                <option value="" selected><%= t('form.placeholders.province') %></option>
            </select>
        </div>

        <div class="form-group">
            <label class="required"><%= t('form.fields.city') %></label>
            <select name="cityCode" id="citySelect" required disabled>
                <option value="" selected><%= t('form.placeholders.city') %></option>
            </select>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.county') %></label>
            <select name="countyCode" id="countySelect" disabled>
                <option value="" selected><%= t('form.placeholders.countyInitial') %></option>
            </select>
        </div>

        <div class="form-group">
            <label class="required"><%= t('form.fields.schoolName') %></label>
            <div class="autocomplete-field">
                <input type="text" name="school_name" id="school_input" placeholder="<%= t('form.placeholders.schoolName') %>" maxlength="<%= formRules.schoolName.maxLength %>" autocomplete="off" required>
                <div id="school_results_list" class="autocomplete-results" hidden></div>
            </div>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.schoolAddress') %></label>
            <div class="autocomplete-field">
                <input type="text" name="school_address" placeholder="<%= t('form.placeholders.schoolAddress') %>" id="addr" maxlength="<%= formRules.schoolAddress.maxLength %>" autocomplete="off">
                <div id="address_results_list" class="autocomplete-results" hidden></div>
            </div>
            <button id="openMapButton" type="button"><%= t('form.buttons.openMap') %></button>
            <div id="map" style="display: none; width: 100%; height: 20em;"></div>
        </div>

        <h3><%= t('form.sections.experience') %></h3>

        <div class="form-group">
            <label class="required"><%= t('form.fields.dateStart') %></label>
            <input type="date" name="date_start" id="date_start" required>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.dateEnd') %></label>
            <input type="date" name="date_end" id="date_end">
            <div class="hint"><%= t('form.hints.dateEnd') %></div>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.experience') %></label>
            <textarea name="experience" id="experienceInput" rows="4" placeholder="<%= t('form.placeholders.experience') %>" maxlength="<%= formRules.experience.maxLength %>"></textarea>
        </div>

        <h3><%= t('form.sections.exposure') %></h3>

        <div class="form-group">
            <label><%= t('form.fields.headmasterName') %></label>
            <input type="text" name="headmaster_name" placeholder="<%= t('form.placeholders.headmasterName') %>" maxlength="<%= formRules.headmasterName.maxLength %>">
        </div>

        <div class="form-group">
            <label class="required"><%= t('form.fields.contactInformation') %></label>
            <input type="text" rows="3" id="contactInformationInput" name="contact_information" placeholder="<%= t('form.placeholders.contactInformation') %>" maxlength="<%= formRules.contactInformation.maxLength %>" required>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.scandal') %></label>
            <textarea name="scandal" rows="3" placeholder="<%= t('form.placeholders.scandal') %>" maxlength="<%= formRules.scandal.maxLength %>"></textarea>
        </div>

        <div class="form-group">
            <label><%= t('form.fields.other') %></label>
            <input type="text" rows="3" name="other" placeholder="<%= t('form.placeholders.other') %>" maxlength="<%= formRules.other.maxLength %>">
        </div>

        <button type="submit"><%= t('form.buttons.submit') %></button>
    </form>
</div>

<script src="/js/map_data_store.js"></script>
<script src="/js/form_api.js"></script>
<script>
    window.AREA_SELECTOR_DATA = <%- JSON.stringify(areaOptions) %>;
    window.FORM_RULES = <%- JSON.stringify(formRules) %>;
</script>
<script src="/js/form_areaSelect.js"></script>
<script>
    // 性別「其他」顯示邏輯
    const i18n = window.I18N;
    const formRules = window.FORM_RULES;
    const mainForm = document.getElementById('mainForm');
    const identitySelect = document.getElementById('identitySelect');
    const birthYearSelect = document.getElementById('birthYearSelect');
    const birthMonthSelect = document.getElementById('birthMonthSelect');
    const birthDaySelect = document.getElementById('birthDaySelect');
    const sexSelect = document.getElementById('sexSelect');
    const otherSexInput = document.getElementById('otherSexInput');
    const provinceSelect = document.getElementById('provinceSelect');
    const citySelect = document.getElementById('citySelect');
    const countySelect = document.getElementById('countySelect');
    const schoolNameInput = document.getElementById('school_input');
    const dateStartInput = document.getElementById('date_start');
    const dateEndInput = document.getElementById('date_end');
    const contactInformationInput = document.getElementById('contactInformationInput');
    const submitButton = mainForm.querySelector('button[type="submit"]');

    function clearValidity(input) {
        input.setCustomValidity('');
    }

    function bindRequiredMessage(input, message) {
        input.addEventListener('invalid', () => {
            if (input.validity.valueMissing) {
                input.setCustomValidity(message);
            } else {
                input.setCustomValidity('');
            }
        });
        input.addEventListener('input', () => clearValidity(input));
        input.addEventListener('change', () => clearValidity(input));
    }

    function toggleOtherSex() {
        const showOtherInput = sexSelect.value === '__other_option__';
        otherSexInput.hidden = !showOtherInput;
        otherSexInput.required = showOtherInput;
        clearValidity(otherSexInput);

        if (!showOtherInput) {
            otherSexInput.value = '';
        }
    }

    function getDaysInMonth(year, month) {
        if (!year || !month) {
            return formRules.birthDay.max;
        }

        return new Date(Number(year), Number(month), 0).getDate();
    }

    function renderBirthDayOptions() {
        const selectedDay = birthDaySelect.value;
        const maxDay = getDaysInMonth(birthYearSelect.value, birthMonthSelect.value);

        birthDaySelect.replaceChildren();

        const placeholderOption = document.createElement('option');
        placeholderOption.value = '';
        placeholderOption.textContent = i18n.form.placeholders.birthDay;
        birthDaySelect.appendChild(placeholderOption);

        for (let day = formRules.birthDay.min; day <= maxDay; day += 1) {
            const option = document.createElement('option');
            option.value = String(day);
            option.textContent = String(day);
            birthDaySelect.appendChild(option);
        }

        birthDaySelect.value = selectedDay && Number(selectedDay) <= maxDay ? selectedDay : '';
    }

    function validateBirthDate() {
        clearValidity(birthYearSelect);
        clearValidity(birthMonthSelect);
        clearValidity(birthDaySelect);

        if (!birthYearSelect.value || !birthMonthSelect.value || !birthDaySelect.value) {
            return;
        }

        const year = Number(birthYearSelect.value);
        const month = Number(birthMonthSelect.value);
        const day = Number(birthDaySelect.value);
        const candidate = new Date(Date.UTC(year, month - 1, day));
        const isValid = candidate.getUTCFullYear() === year
            && candidate.getUTCMonth() === month - 1
            && candidate.getUTCDate() === day;

        if (!isValid) {
            birthDaySelect.setCustomValidity(i18n.form.validation.invalidBirthDate);
        }
    }

    function validateCrossFields() {
        clearValidity(otherSexInput);
        clearValidity(dateEndInput);

        if (sexSelect.value === '__other_option__' && !otherSexInput.value.trim()) {
            otherSexInput.setCustomValidity(i18n.form.validation.specifyOtherSex);
        }

        validateBirthDate();

        const start = dateStartInput.value;
        const end = dateEndInput.value;
        if (end && start && new Date(end) < new Date(start)) {
            dateEndInput.setCustomValidity(i18n.form.validation.endDateBeforeStart);
        }
    }

    bindRequiredMessage(identitySelect, i18n.form.validation.selectIdentity);
    bindRequiredMessage(birthYearSelect, i18n.form.validation.fillBirthDate);
    bindRequiredMessage(birthMonthSelect, i18n.form.validation.fillBirthDate);
    bindRequiredMessage(birthDaySelect, i18n.form.validation.fillBirthDate);
    bindRequiredMessage(sexSelect, i18n.form.validation.selectSex);
    bindRequiredMessage(provinceSelect, i18n.form.validation.selectProvince);
    bindRequiredMessage(citySelect, i18n.form.validation.selectCity);
    bindRequiredMessage(schoolNameInput, i18n.form.validation.fillSchoolName);
    bindRequiredMessage(dateStartInput, i18n.form.validation.fillDateStart);
    bindRequiredMessage(contactInformationInput, i18n.form.validation.fillContactInformation);
    bindRequiredMessage(otherSexInput, i18n.form.validation.specifyOtherSex);

    birthYearSelect.addEventListener('change', () => {
        renderBirthDayOptions();
        validateCrossFields();
    });
    birthMonthSelect.addEventListener('change', () => {
        renderBirthDayOptions();
        validateCrossFields();
    });
    birthDaySelect.addEventListener('change', validateCrossFields);
    citySelect.addEventListener('change', () => clearValidity(countySelect));

    sexSelect.addEventListener('change', toggleOtherSex);
    sexSelect.addEventListener('change', validateCrossFields);
    otherSexInput.addEventListener('input', validateCrossFields);
    dateStartInput.addEventListener('change', validateCrossFields);
    dateEndInput.addEventListener('change', validateCrossFields);
    renderBirthDayOptions();
    toggleOtherSex();
    validateCrossFields();

    mainForm.addEventListener('submit', function(e) {
        validateCrossFields();
        if (!mainForm.checkValidity()) {
            e.preventDefault();
            mainForm.reportValidity();
            return;
        }

        if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = i18n.form.buttons.submitting || i18n.common.loading;
        }
    });
</script>
<script src="/js/form_mapChoose.js"></script>
<%- include('partials/foot') %>
</body>
</html>
