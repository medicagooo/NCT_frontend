<%- include('partials/head') %>
<body>
    <a href="/" class="page-back-link">← <%= t('navigation.home') %></a>
    <% const privacy = t('privacy'); %>
    <main class="about-page privacy-page">
        <section class="div privacy-hero">
            <p class="privacy-page__eyebrow"><%= t('navigation.privacy') %></p>
            <h1><%= privacy.title %></h1>
            <p class="privacy-page__intro"><%= privacy.intro %></p>
            <dl class="privacy-meta">
                <div class="privacy-meta__row">
                    <dt><%= privacy.meta.effectiveDateLabel %></dt>
                    <dd><%= privacy.meta.effectiveDateValue %></dd>
                </div>
                <div class="privacy-meta__row">
                    <dt><%= privacy.meta.updatedLabel %></dt>
                    <dd><%= privacy.meta.updatedValue %></dd>
                </div>
                <div class="privacy-meta__row">
                    <dt><%= privacy.meta.scopeLabel %></dt>
                    <dd><%= privacy.meta.scopeValue %></dd>
                </div>
            </dl>
        </section>

        <nav class="div privacy-toc" aria-label="<%= privacy.tocLabel %>">
            <a class="privacy-toc__link" href="#privacy-overview"><%= privacy.sections.summary %></a>
            <a class="privacy-toc__link" href="#privacy-form"><%= privacy.sections.formSubmission %></a>
            <a class="privacy-toc__link" href="#privacy-cookie"><%= privacy.sections.cookie %></a>
            <a class="privacy-toc__link" href="#privacy-third-party"><%= privacy.sections.thirdParty %></a>
            <a class="privacy-toc__link" href="#privacy-retention"><%= privacy.sections.retention %></a>
            <a class="privacy-toc__link" href="#privacy-security"><%= privacy.sections.security %></a>
            <a class="privacy-toc__link" href="#privacy-manage"><%= privacy.sections.manage %></a>
            <a class="privacy-toc__link" href="#privacy-contact"><%= privacy.sections.contact %></a>
            <a
                class="privacy-toc__link"
                href="https://docs.google.com/spreadsheets/d/12GSD0Hzi0P6q3B9V4-DT9SOQghL8zV2A-7FsWFYhFxk"
                target="_blank"
                rel="noopener noreferrer"
            ><%= privacy.sections.publicInfo %></a>
        </nav>

        <section class="div privacy-section" id="privacy-overview">
            <h2 class="privacy-section__title"><%= privacy.sections.summary %></h2>
            <p class="privacy-section__lead"><%= privacy.summary %></p>
            <div class="privacy-highlight-grid">
                <article class="privacy-highlight-card">
                    <h3 class="privacy-highlight-card__title"><%= privacy.highlights.submissionTitle %></h3>
                    <p><%= privacy.highlights.submissionBody %></p>
                </article>
                <article class="privacy-highlight-card">
                    <h3 class="privacy-highlight-card__title"><%= privacy.highlights.publicTitle %></h3>
                    <p><%= privacy.highlights.publicBody %></p>
                </article>
                <article class="privacy-highlight-card">
                    <h3 class="privacy-highlight-card__title"><%= privacy.highlights.cookieTitle %></h3>
                    <p><%= privacy.highlights.cookieBody %></p>
                </article>
            </div>
            <ul class="privacy-list">
                <% privacy.overviewItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section" id="privacy-form">
            <h2 class="privacy-section__title"><%= privacy.sections.formSubmission %></h2>
            <p class="privacy-section__lead"><%= privacy.formLead %></p>
            <p class="privacy-page__notice"><%= t('form.privacyNotice') %></p>
            <ul class="privacy-list">
                <% privacy.formItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section" id="privacy-cookie">
            <h2 class="privacy-section__title"><%= privacy.sections.cookie %></h2>
            <p class="privacy-section__lead"><%= privacy.cookieIntro %></p>
            <dl class="privacy-cookie-list">
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.name %></dt>
                    <dd><code>lang</code></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.purpose %></dt>
                    <dd><%= privacy.cookieValues.purpose %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.trigger %></dt>
                    <dd><%= privacy.cookieValues.trigger %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.retention %></dt>
                    <dd><%= privacy.cookieValues.retention %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.scope %></dt>
                    <dd><%= privacy.cookieValues.scope %></dd>
                </div>
                <div class="privacy-cookie-list__row">
                    <dt><%= privacy.cookieFields.attributes %></dt>
                    <dd><%= privacy.cookieValues.attributes %></dd>
                </div>
            </dl>
        </section>

        <section class="div privacy-section" id="privacy-third-party">
            <h2 class="privacy-section__title"><%= privacy.sections.thirdParty %></h2>
            <p class="privacy-section__lead"><%= privacy.thirdPartyLead %></p>
            <ul class="privacy-list">
                <% privacy.thirdPartyItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section" id="privacy-retention">
            <h2 class="privacy-section__title"><%= privacy.sections.retention %></h2>
            <ul class="privacy-list">
                <% privacy.retentionItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section" id="privacy-security">
            <h2 class="privacy-section__title"><%= privacy.sections.security %></h2>
            <ul class="privacy-list">
                <% privacy.securityItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section" id="privacy-manage">
            <h2 class="privacy-section__title"><%= privacy.sections.manage %></h2>
            <ul class="privacy-list">
                <% privacy.manageItems.forEach((item) => { %>
                    <li><%= item %></li>
                <% }) %>
            </ul>
        </section>

        <section class="div privacy-section privacy-section--contact" id="privacy-contact">
            <h2 class="privacy-section__title"><%= privacy.sections.contact %></h2>
            <p class="privacy-section__lead"><%= privacy.contactBody %></p>
            <p class="privacy-page__contact"><a href="mailto:notorsion@hosinoneko.me">notorsion@hosinoneko.me</a></p>
        </section>
    </main>

    <%- include('partials/foot') %>
</body>
</html>
