<!DOCTYPE html>
<html lang="<%= lang %>">
<%- include('partials/standalone_head') %>
<body class="standalone-liquid-page standalone-liquid-page--form">
    <main class="standalone-shell standalone-form-shell">
        <%- include('partials/standalone_language_picker') %>

        <section class="glass-panel standalone-hero">
            <div>
                <h1><%= t('form.standalone.title') %></h1>
                <p class="standalone-hero__subtitle"><%= t('form.subtitle') %></p>
                <p class="standalone-hero__note form-privacy-note">
                    <%= t('form.privacyNotice') %> <strong><%= t('form.standalone.safetyNotice') %></strong>
                </p>
            </div>
        </section>

        <form action="<%= submitAction || '/submit' %>" method="POST" id="mainForm" class="report-form standalone-report-form">
            <div class="form-honeypot" aria-hidden="true">
                <label for="website"><%= t('form.standalone.honeypotLabel') %></label>
                <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" spellcheck="false">
            </div>
            <input type="hidden" name="form_token" value="<%= formProtectionToken %>">

            <section class="glass-panel form-section">
                <div class="section-heading">
                    <h2><%= t('form.sections.basic') %></h2>
                </div>

                <div class="form-grid form-grid--two">
                    <div class="form-group form-field--full">
                        <label class="required"><%= t('form.fields.identity') %></label>
                        <select name="identity" id="identitySelect" required>
                            <% identityOptions.forEach((option) => { %>
                                <option value="<%= option.value %>"><%= option.label %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group form-field--full" id="agentRelationshipGroup" hidden>
                        <label for="agentRelationshipSelect"><%= t('form.fields.agentRelationship') %></label>
                        <select name="agent_relationship" id="agentRelationshipSelect" disabled>
                            <option value="" selected><%= t('form.placeholders.agentRelationship') %></option>
                            <% agentRelationshipOptions.forEach((option) => { %>
                                <option value="<%= option.value %>"><%= option.label %></option>
                            <% }) %>
                        </select>
                        <div id="agentRelationshipOtherWrap" class="form-conditional-fields" hidden>
                            <input
                                type="text"
                                id="agentRelationshipOtherInput"
                                name="agent_relationship_other"
                                placeholder="<%= t('form.placeholders.agentRelationshipOther') %>"
                                maxlength="<%= formRules.agentRelationship.maxLength %>"
                                disabled
                            >
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="required" id="birthFieldLabel" for="birthYearSelect"><%= t('form.fields.birthYear') %></label>
                        <div class="birth-date-group birth-date-group--single" id="birthYearSelectWrap" role="group" aria-labelledby="birthFieldLabel">
                            <select name="birth_year" id="birthYearSelect" required>
                                <option value="" selected><%= t('form.placeholders.birthYear') %></option>
                                <% for (let year = formRules.birthYear.max; year >= formRules.birthYear.min; year -= 1) { %>
                                    <option value="<%= year %>"><%= year %></option>
                                <% } %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="required" id="sexLabel" for="sexSelect"><%= t('form.fields.sex') %></label>
                        <select name="sex" id="sexSelect" required>
                            <option value="" disabled selected><%= t('form.sexOptions.placeholder') %></option>
                            <% sexOptions.forEach((option) => { %>
                                <option value="<%= option.value %>"><%= option.label %></option>
                            <% }) %>
                        </select>
                        <div id="otherSexFields" class="form-conditional-fields" hidden>
                            <div class="other-sex-options" role="radiogroup" aria-label="<%= t('fields.sexOther') %>">
                                <% otherSexTypeOptions.forEach((option) => { %>
                                    <label class="other-sex-option">
                                        <input type="radio" name="sex_other_type" value="<%= option.value %>" class="other-sex-radio" disabled>
                                        <span><%= option.label %></span>
                                    </label>
                                <% }) %>
                                <label class="other-sex-option other-sex-option--custom">
                                    <input type="radio" id="otherSexCustomRadio" name="sex_other_type" value="__custom_other_sex__" class="other-sex-radio" disabled>
                                    <input
                                        type="text"
                                        id="otherSexInput"
                                        name="sex_other"
                                        class="other-input other-input--choice"
                                        placeholder="<%= t('form.placeholders.otherSex') %>"
                                        aria-label="<%= t('fields.sexOther') %>"
                                        maxlength="<%= formRules.sexOther.maxLength %>"
                                        disabled
                                    >
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="glass-panel form-section">
                <div class="section-heading">
                    <h2 id="experienceSectionHeading"><%= t('form.sections.experience') %></h2>
                </div>

                <div class="form-grid form-grid--two">
                    <div class="form-group">
                        <label for="preInstitutionProvinceSelect"><%= t('form.fields.preInstitutionProvinceCode') %></label>
                        <select name="pre_institution_province_code" id="preInstitutionProvinceSelect">
                            <option value="" selected><%= t('form.placeholders.preInstitutionProvinceCode') %></option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="preInstitutionCitySelect"><%= t('form.fields.preInstitutionCityCode') %></label>
                        <select name="pre_institution_city_code" id="preInstitutionCitySelect" disabled>
                            <option value="" selected><%= t('form.placeholders.preInstitutionCityCode') %></option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="required" for="date_start"><%= t('form.fields.dateStart') %></label>
                        <input type="date" name="date_start" id="date_start" required>
                        <div class="hint"><%= t('form.hints.dateStart') %></div>
                    </div>

                    <div class="form-group">
                        <label for="date_end"><%= t('form.fields.dateEnd') %></label>
                        <input type="date" name="date_end" id="date_end">
                        <div class="hint"><%= t('form.hints.dateEnd') %></div>
                    </div>

                    <div class="form-group form-field--full">
                        <label class="required"><%= t('form.fields.parentMotivations') %></label>
                        <div class="choice-grid" id="parentMotivationGroup">
                            <% parentMotivationOptions.forEach((option, index) => { %>
                                <label class="choice-option" for="parentMotivation-<%= index %>">
                                    <input
                                        type="checkbox"
                                        id="parentMotivation-<%= index %>"
                                        name="parent_motivations"
                                        value="<%= option.value %>"
                                        class="choice-input parent-motivation-checkbox"
                                    >
                                    <span><%= option.label %></span>
                                </label>
                            <% }) %>
                        </div>
                        <div id="parentMotivationOtherWrap" class="form-conditional-fields" hidden>
                            <input
                                type="text"
                                id="parentMotivationOtherInput"
                                name="parent_motivation_other"
                                placeholder="<%= t('form.placeholders.parentMotivationOther') %>"
                                maxlength="<%= formRules.parentMotivationOther.maxLength %>"
                                disabled
                            >
                        </div>
                    </div>

                    <div class="form-group form-field--full" id="exitMethodGroup" hidden>
                        <label for="exitMethodSelect"><%= t('form.fields.exitMethod') %></label>
                        <select name="exit_method" id="exitMethodSelect" disabled>
                            <option value="" selected><%= t('form.placeholders.exitMethod') %></option>
                            <% exitMethodOptions.forEach((option) => { %>
                                <option value="<%= option.value %>"><%= option.label %></option>
                            <% }) %>
                        </select>
                        <div id="exitMethodOtherWrap" class="form-conditional-fields" hidden>
                            <input
                                type="text"
                                id="exitMethodOtherInput"
                                name="exit_method_other"
                                placeholder="<%= t('form.placeholders.exitMethodOther') %>"
                                maxlength="<%= formRules.exitMethodOther.maxLength %>"
                                disabled
                            >
                        </div>
                    </div>

                    <div class="form-group form-field--full">
                        <label for="experienceInput"><%= t('form.fields.experience') %></label>
                        <textarea name="experience" id="experienceInput" rows="4" placeholder="<%= t('form.placeholders.experience') %>" maxlength="<%= formRules.experience.maxLength %>"></textarea>
                        <div class="hint"><%= t('form.hints.experience') %></div>
                    </div>

                    <div class="form-group form-field--full">
                        <label for="legalAidSelect"><%= t('form.fields.legalAidStatus') %></label>
                        <select name="legal_aid_status" id="legalAidSelect">
                            <option value="" selected><%= t('form.placeholders.legalAidStatus') %></option>
                            <% legalAidOptions.forEach((option) => { %>
                                <option value="<%= option.value %>"><%= option.label %></option>
                            <% }) %>
                        </select>
                        <div id="legalAidOtherWrap" class="form-conditional-fields" hidden>
                            <input
                                type="text"
                                id="legalAidOtherInput"
                                name="legal_aid_other"
                                placeholder="<%= t('form.placeholders.legalAidOther') %>"
                                maxlength="<%= formRules.legalAidOther.maxLength %>"
                                disabled
                            >
                        </div>
                    </div>
                </div>
            </section>

            <section class="glass-panel form-section">
                <div class="section-heading">
                    <h2><%= t('form.sections.exposure') %></h2>
                </div>

                <div class="form-grid form-grid--two">
                    <div class="form-group form-field--full">
                        <label class="required" for="school_input"><%= t('form.fields.schoolName') %></label>
                        <div class="autocomplete-field">
                            <input type="text" name="school_name" id="school_input" placeholder="<%= t('form.placeholders.schoolName') %>" maxlength="<%= formRules.schoolName.maxLength %>" autocomplete="off" required>
                            <div id="school_results_list" class="autocomplete-results" hidden></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="required" for="provinceSelect"><%= t('form.fields.province') %></label>
                        <select name="provinceCode" id="provinceSelect" required>
                            <option value="" selected><%= t('form.placeholders.province') %></option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="required" for="citySelect"><%= t('form.fields.city') %></label>
                        <select name="cityCode" id="citySelect" required disabled>
                            <option value="" selected><%= t('form.placeholders.city') %></option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="countySelect"><%= t('form.fields.county') %></label>
                        <select name="countyCode" id="countySelect" disabled>
                            <option value="" selected><%= t('form.placeholders.countyInitial') %></option>
                        </select>
                    </div>

                    <div class="form-group form-field--full">
                        <label for="addr"><%= t('form.fields.schoolAddress') %></label>
                        <div class="autocomplete-field">
                            <input type="text" name="school_address" placeholder="<%= t('form.placeholders.schoolAddress') %>" id="addr" maxlength="<%= formRules.schoolAddress.maxLength %>" autocomplete="off">
                            <div id="address_results_list" class="autocomplete-results" hidden></div>
                        </div>
                        <div class="form-location-actions">
                            <button id="openMapButton" class="form-location-action" type="button"><%= t('form.buttons.openMap') %></button>
                            <button id="getCurrentLocationButton" class="form-location-action" type="button"><%= t('form.buttons.getCurrentLocation') %></button>
                        </div>
                        <div id="locationStatus" class="hint form-location-status" role="status" aria-live="polite" aria-atomic="true"></div>
                        <div id="map" class="standalone-map" style="display: none;"></div>
                    </div>

                    <div class="form-group">
                        <label class="required" for="contactInformationInput"><%= t('form.fields.contactInformation') %></label>
                        <input type="text" id="contactInformationInput" name="contact_information" placeholder="<%= t('form.placeholders.contactInformation') %>" maxlength="<%= formRules.contactInformation.maxLength %>" required>
                    </div>

                    <div class="form-group">
                        <label for="headmaster_name"><%= t('form.fields.headmasterName') %></label>
                        <input type="text" id="headmaster_name" name="headmaster_name" placeholder="<%= t('form.placeholders.headmasterName') %>" maxlength="<%= formRules.headmasterName.maxLength %>">
                    </div>

                    <div class="form-group form-field--full">
                        <label for="abuserInfoInput"><%= t('form.fields.abuserInfo') %></label>
                        <textarea
                            id="abuserInfoInput"
                            name="abuser_info"
                            rows="3"
                            placeholder="<%= t('form.placeholders.abuserInfo') %>"
                            maxlength="<%= formRules.abuserInfo.maxLength %>"
                        ></textarea>
                    </div>

                    <div class="form-group form-field--full">
                        <label><%= t('form.fields.violenceCategories') %></label>
                        <div class="choice-grid" id="violenceCategoryGroup">
                            <% violenceCategoryOptions.forEach((option, index) => { %>
                                <label class="choice-option" for="violenceCategory-<%= index %>">
                                    <input
                                        type="checkbox"
                                        id="violenceCategory-<%= index %>"
                                        name="violence_categories"
                                        value="<%= option.value %>"
                                        class="choice-input violence-category-checkbox"
                                    >
                                    <span><%= option.label %></span>
                                </label>
                            <% }) %>
                        </div>
                        <div id="violenceCategoryOtherWrap" class="form-conditional-fields" hidden>
                            <input
                                type="text"
                                id="violenceCategoryOtherInput"
                                name="violence_category_other"
                                placeholder="<%= t('form.placeholders.violenceCategoryOther') %>"
                                maxlength="<%= formRules.violenceCategoryOther.maxLength %>"
                                disabled
                            >
                        </div>
                    </div>

                    <div class="form-group form-field--full">
                        <label for="scandal"><%= t('form.fields.scandal') %></label>
                        <textarea name="scandal" id="scandal" rows="3" placeholder="<%= t('form.placeholders.scandal') %>" maxlength="<%= formRules.scandal.maxLength %>"></textarea>
                    </div>

                    <div class="form-group form-field--full">
                        <label for="other"><%= t('form.fields.other') %></label>
                        <textarea id="other" name="other" rows="3" placeholder="<%= t('form.placeholders.other') %>" maxlength="<%= formRules.other.maxLength %>"></textarea>
                    </div>
                </div>
            </section>

            <div class="standalone-submit-row">
                <button type="submit" class="standalone-submit-button"><%= t('form.buttons.submit') %></button>
            </div>
        </form>

        <%- include('partials/standalone_foot') %>
    </main>

    <script src="/js/map_data_store.js"></script>
    <script src="/js/form_api.js"></script>
    <script>
        window.AREA_SELECTOR_DATA = <%- JSON.stringify(areaOptions) %>;
        window.FORM_RULES = <%- JSON.stringify(formRules) %>;
    </script>
    <script src="/js/form_areaSelect.js"></script>
    <script src="/js/standalone_form.js"></script>
    <script src="/js/form_mapChoose.js"></script>
</body>
</html>
