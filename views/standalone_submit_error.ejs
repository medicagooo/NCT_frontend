<!DOCTYPE html>
<html lang="<%= lang %>">
<%- include('partials/standalone_head') %>
<body class="standalone-liquid-page">
    <main class="standalone-shell standalone-shell--narrow standalone-stack">
        <a href="<%= typeof backFormUrl !== 'undefined' && backFormUrl ? backFormUrl : '/form/standalone' %>" class="standalone-back-link">← <%= t('submitError.backForm') %></a>

        <section class="glass-panel standalone-state-card standalone-state-card--error">
            <div>
                <p class="glass-eyebrow">Retry</p>
                <h1><%= t('submitError.title') %></h1>
                <p class="standalone-state-card__intro"><%= t('submitError.intro') %></p>
            </div>

            <% if (showSubmissionDiagnostics && submissionDiagnostics) { %>
                <div class="standalone-diagnostics">
                    <h2><%= t('submitStatus.title') %></h2>
                    <p><strong><%= t('submitStatus.mode') %></strong> <%= submissionDiagnostics.attemptedTargets.map((target) => target.label).join(' / ') %></p>
                    <p><strong><%= t('submitStatus.successfulTargets') %></strong> <%= submissionDiagnostics.successfulTargets.length > 0 ? submissionDiagnostics.successfulTargets.map((target) => target.label).join(' / ') : t('submitStatus.none') %></p>
                    <p><strong><%= t('submitStatus.failedTargets') %></strong> <%= submissionDiagnostics.failedTargets.length > 0 ? submissionDiagnostics.failedTargets.map((target) => target.label).join(' / ') : t('submitStatus.none') %></p>
                    <% if (submissionDiagnostics.failedTargets.length > 0) { %>
                        <div class="standalone-diagnostics__errors">
                            <% submissionDiagnostics.failedTargets.forEach((target) => { %>
                                <p><strong><%= target.label %></strong> <%= t('submitStatus.error') %><%= target.error %></p>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            <% } %>

            <div class="standalone-actions">
                <% if (fallbackUrl) { %>
                    <a href="<%= fallbackUrl %>" target="_blank" rel="noopener noreferrer" class="button-primary"><%= t('submitError.openFallback') %></a>
                <% } %>
                <a href="<%= typeof backFormUrl !== 'undefined' && backFormUrl ? backFormUrl : '/form/standalone' %>"><%= t('submitError.backForm') %></a>
            </div>

            <% if (fallbackUrl) { %>
                <p class="standalone-note"><%= t('submitError.privacyNote') %></p>
                <p class="standalone-note"><%= t('submitError.proxyNote') %></p>
                <label for="fallbackUrlBox"><strong><%= t('submitError.urlLabel') %></strong></label>
                <textarea id="fallbackUrlBox" class="standalone-url-box" readonly><%= fallbackUrl %></textarea>
            <% } %>
        </section>

        <%- include('partials/standalone_foot') %>
    </main>
</body>
</html>
