<%- include('partials/head') %>
<html>
<body>
    <div>
        <a href="/blog" class="page-back-link">← <%= t('navigation.allArticles') %></a>
    </div>

    <div class="div blog-article-card" style="width: 70%;">
        <% reports.forEach(report => { %>
        <main class="main blog-article">
                <div class="port" id="markdown">
                    <%- report.html %>
                </div>
            </main>
        <% }) %>
    </div>
    <% // 只有英文文章页会在前端按段落补充双语翻译，其它语言直接显示服务端渲染结果。 %>
    <% if (lang === 'en') { %>
        <script src="/js/blog_article_translation.js"></script>
    <% } %>
    <%- include('partials/foot') %>
</body>
</html>
