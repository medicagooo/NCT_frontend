<!DOCTYPE html>
<html lang="<%= lang %>">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="color-scheme" content="light dark">
        <% if (typeof pageRobots !== 'undefined' && pageRobots) { %>
        <meta name="robots" content="<%= pageRobots %>">
        <% } %>
        <title><%= title %></title>
        <link rel="stylesheet" href="/css/main.css?v=<%= assetVersion %>">
        <script>
            window.APP_LANG = "<%= lang %>";
            window.I18N = <%- JSON.stringify(clientMessages) %>;
        </script>
        <style>
            body {
                padding: 2rem 1rem 4rem;
            }
            .confirm-container {
                width: min(100%, 960px);
                margin: 0 auto;
            }
            .confirm-summary {
                word-break: break-word;
            }
            .confirm-table-wrap {
                width: 100%;
                margin-top: 1.5rem;
                overflow-x: auto;
                border-radius: 14px;
                box-shadow: var(--shadow-soft);
                -webkit-overflow-scrolling: touch;
            }
            .confirm-table {
                width: 100%;
                border-collapse: collapse;
                background: var(--card-bg);
                color: var(--text);
                min-width: 420px;
            }
            .confirm-table th,
            .confirm-table td {
                border: 1px solid var(--panel-border);
                padding: 0.75rem;
                text-align: left;
                vertical-align: top;
            }
            .confirm-table th {
                background: var(--surface-soft);
            }
            .confirm-actions {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                margin-top: 1.5rem;
            }
            .confirm-actions a,
            .confirm-actions button {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 2.75rem;
                padding: 0.8rem 1rem;
                border-radius: 12px;
                border: 1px solid var(--panel-border);
                box-sizing: border-box;
                text-align: center;
            }
            .confirm-actions a {
                background: linear-gradient(135deg, rgba(52, 152, 219, 0.12), rgba(93, 173, 226, 0.22));
            }
            .confirm-actions button {
                width: auto;
                margin-top: 0;
            }
            @media (max-width: 720px) {
                body {
                    padding: 1.25rem 0.75rem 2rem;
                }
                .confirm-container {
                    width: 100%;
                }
                .confirm-table-wrap {
                    margin-top: 1rem;
                    border-radius: 12px;
                }
                .confirm-table th,
                .confirm-table td {
                    padding: 0.65rem;
                    font-size: 0.92rem;
                }
                .confirm-actions {
                    flex-direction: column;
                }
                .confirm-actions a,
                .confirm-actions button {
                    width: 100%;
                }
            }
            @media (max-width: 480px) {
                body {
                    padding: 1rem 0.6rem 1.5rem;
                }
                .confirm-table th,
                .confirm-table td {
                    padding: 0.58rem;
                    font-size: 0.86rem;
                }
            }
        </style>
    </head>
    <body>
        <div class="confirm-container">
            <h1><%= t('submitConfirm.title') %></h1>
            <p><%= t('submitConfirm.intro') %></p>
            <div class="confirm-table-wrap">
                <table class="confirm-table">
                    <thead>
                        <tr>
                            <th><%= t('submitConfirm.columns.field') %></th>
                            <th><%= t('submitConfirm.columns.value') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% fields.forEach((field) => { %>
                            <tr>
                                <td><%= field.label %></td>
                                <td><%= field.value %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <form action="/submit/confirm" method="POST" id="confirmForm">
                <input type="hidden" name="confirmation_token" value="<%= confirmationToken %>">
                <textarea name="confirmation_payload" hidden><%= confirmationPayload %></textarea>
                <div class="confirm-actions">
                    <a href="/form"><%= t('submitConfirm.backForm') %></a>
                    <button type="submit" id="confirmSubmitButton"><%= t('submitConfirm.confirm') %></button>
                </div>
            </form>
        </div>
        <script>
            const confirmForm = document.getElementById('confirmForm');
            const confirmSubmitButton = document.getElementById('confirmSubmitButton');
            const i18n = window.I18N;

            if (confirmForm && confirmSubmitButton) {
                confirmForm.addEventListener('submit', () => {
                    confirmSubmitButton.disabled = true;
                    confirmSubmitButton.textContent = i18n.submitConfirm.confirming || i18n.common.loading;
                });
            }
        </script>
        <%- include('partials/foot') %>
    </body>
</html>
