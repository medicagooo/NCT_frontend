<!DOCTYPE html>
<html lang="<%= lang %>">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="color-scheme" content="light dark">
        <title><%- title %></title>
        <link rel="stylesheet" href="/css/index.css?v=<%= assetVersion %>">
        <link rel="icon" href="/favicon.svg"/>
        <script>
            window.API_URL = "<%= apiUrl %>";
            window.APP_LANG = "<%= lang %>";
            window.I18N = <%- JSON.stringify(clientMessages) %>;
        </script>
        <script type="application/ld+json">
            {
            /* 1. 协议声明：必须固定为 https://schema.org，这相当于告诉爬虫“我要开始按标准说话了” */
            "@context": "https://schema.org",

            /* 2. 类型声明：这里用 Organization（组织） */
            "@type": "Organization", 

            /* 3. 页面唯一标识：告诉爬虫这个数据描述的具体是哪个网址 */
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": "https://www.victimsunion.org" 
            },

            /* 4. SEO 标题：这是爬虫最看重的关键词权重区，建议包含核心词 */
            "name": "Victims Union",
            "headline": "终结扭转治疗：NCT 揭露戒网瘾学校真相",

            /* 5. 摘要描述：在搜索结果预览中可能会显示这段话，一定要顺畅地埋入“扭转机构”等词 */
            "description": "Victims Union 是由扭转治疗幸存者组成的独立组织，致力于曝光戒网瘾学校及扭转机构的身心折磨。我们坚信每个声音都不该被沉默。",

            /* 6. 封面图：有图片的文章更容易在搜索结果里展示大图，增加点击率 */
            "image": "https://www.victimsunion.org/favicon.svg", 

            /* 7. 作者信息：建立你的组织公信力（EEAT） */
            "author": {
                "@type": "Person",
                "name": "HosinoNeko",
                "url": "https://hosinoneko.me"
            },

            /* 8. 发布者信息：这里定义你的“Victims Union”组织身份 */
            "publisher": {
                "@type": "Organization",
                "name": "Victims Union",
                "url": "https://victimsunion.org",
                "logo": {
                    "@type": "ImageObject",
                    "url": "https://www.victimsunion.org/favicon.svg"
                }
            },

            /* 9. 核心关键词：虽然不直接显示，但有助于爬虫进行分类索引 */
            "keywords": "CONVERSION THERAPY, 戒网瘾学校, 扭转机构, LGBTQIA"
            }
        </script>
    </head>
    <body>
        <%- include('partials/language_switcher') %><!--語言轉換器-->

        <div class="hero">
            <h1><%= t('common.siteName') %></h1>
            <p>
                <%= t('index.tagline') %>
            </p>
            <div class="hero__actions">
                <a href="/form" class="btn"><%= t('index.fillForm') %></a>
                <a href="/map?inputType=受害者本人" class="btn"><%= t('index.viewMap') %></a>
                <a href="/blog" class="btn btn--library"><%= t('index.blogLibrary') %></a>
            </div>
        </div>

        <script src="/js/map_data_store.js"></script>
        <script src="/js/map_preload.js"></script>
        <script src="/js/language_switcher.js"></script>
        <%- include('partials/foot') %>
        <noscript>
            <section>
                <h2>专业揭露戒网瘾学校与扭转机构真相</h2>
                <p>Victims Union 致力于记录和曝光全国各地的非法扭转治疗机构。我们提供实时的戒网瘾学校地图，帮助 LGBTQIA 群体与青少年避开身心折磨。</p>
                <ul>
                <li><a href="/map">查看全国戒网瘾学校分布图</a></li>
                <li><a href="/blog">阅读扭转机构相关文章</a></li>
                </ul>
            </section>
        </noscript>
    </body>
</html>
