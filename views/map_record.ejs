<%- include('partials/head', {
    extraHeadPartial: 'partials/map_record_head'
}) %>
<body class="map-page map-record-page">
    <a href="/map" id="mapRecordBackLink" class="page-back-link">← <%= t('map.record.backToMap') %></a>
    <script src="/js/map_data_store.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_record_stats.js?v=<%= assetVersion %>"></script>
    <script src="/js/map_record_detail.js?v=<%= assetVersion %>"></script>
    <script>
        window.MAP_RECORD_PAGE = {
            recordSlug: <%- JSON.stringify(recordSlug || '') %>
        };
    </script>
    <main class="map-record-page__layout">
        <section class="div map-record-page__hero">
            <p id="mapRecordEyebrow" class="map-record-page__eyebrow"><%= t('map.record.loading') %></p>
            <h1 id="mapRecordTitle"><%= t('map.record.loading') %></h1>
            <p id="mapRecordMeta" class="map-record-page__meta"></p>
            <div id="mapRecordCounts" class="map-record-page__counts" hidden></div>
        </section>
        <section class="div map-record-page__panel">
            <p id="mapRecordStatus" class="map-record-page__status"><%= t('map.record.loading') %></p>
            <div id="mapRecordTableWrap" class="map-record-detail-panel__table-wrap" hidden>
                <table class="map-record-detail-panel__table">
                    <thead>
                        <tr>
                            <th><%= t('submitConfirm.columns.field') %></th>
                            <th><%= t('submitConfirm.columns.value') %></th>
                        </tr>
                    </thead>
                    <tbody id="mapRecordDetailTableBody"></tbody>
                </table>
            </div>
            <div id="mapRecordPaginationBottom"></div>
        </section>
    </main>
    <script src="/js/map_record_page.js?v=<%= assetVersion %>"></script>
    <%- include('partials/foot') %>
</body>
</html>
