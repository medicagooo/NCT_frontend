{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "server.js": {
      "includeFiles": "{views/**/*.ejs,blog/**/*.md,data.json,friends.json}"
    }
  }
}
